# Echo-Orchestra environment variables
# Copy this file to .env and fill in the keys you have.
# Minimum to run LOOP-01: PERPLEXITY_API_KEY + one model key (DEEPSEEK_API_KEY is cheapest).

# --- Research layer (required) ---
PERPLEXITY_API_KEY=

# --- Model providers (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# --- Stripe (for automatic revenue logging) ---
STRIPE_WEBHOOK_SECRET=
STRIPE_API_KEY=

# --- Runtime ---
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_PROXY_KEY=sk-echo-local
DATABASE_URL=sqlite:///echo_ledger.db
DEFAULT_CURRENCY=USD
DEFAULT_JURISDICTION=US
LOG_LEVEL=INFO
LOG_DIR=./logs
